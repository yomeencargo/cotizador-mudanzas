# Panel admin (solo servidor; nunca uses NEXT_PUBLIC_ para la contraseña)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=tu-password-admin-seguro

#SUPABASE
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=tu-supabase-service-role-key

#GEOAPIFY
NEXT_PUBLIC_GEOAPIFY_API_KEY=tu-geoapify-api-key

# Flow Payment Gateway
# Sandbox (pruebas): https://sandbox.flow.cl/api
# Producción:        https://www.flow.cl/api
FLOW_API_KEY=tu-flow-api-key
FLOW_SECRET_KEY=tu-flow-secret-key
FLOW_API_URL=https://sandbox.flow.cl/api

# Application URL (para callbacks de Flow)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# n8n - Webhook que envía el correo de cotización (SMTP lo maneja n8n, no el sitio)
N8N_QUOTE_WEBHOOK_URL=https://core.zensus.cl/webhook/tu-webhook-id

# Tracking (GTM y Meta Pixel)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
NEXT_PUBLIC_META_PIXEL_ID=XXXXXXXXXXXXXXX
